{% comment %} All collections page. Depends on: none. {% endcomment %}
{% style %}
  .collections-{{ section.id }} { padding: var(--section-space) 0; }
  .collections-{{ section.id }}__title { font-size: var(--f7); margin-bottom: 32px; }
  .collections-{{ section.id }}__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: clamp(12px, 2vw, 24px); }
  .collections-{{ section.id }}__card { display: block; }
  .collections-{{ section.id }}__media { aspect-ratio: 4 / 3; border-radius: 12px; overflow: hidden; background: var(--color-surface); margin-bottom: 10px; }
  .collections-{{ section.id }}__media img, .collections-{{ section.id }}__media svg { width: 100%; height: 100%; object-fit: cover; }
  .collections-{{ section.id }}__name { font-family: var(--font-heading); font-weight: 600; font-size: var(--f3); }
  @media (min-width: 800px) { .collections-{{ section.id }}__grid { grid-template-columns: repeat(3, 1fr); } }
{% endstyle %}

<section class='collections-{{ section.id }}' data-reveal='up'>
  <div class='container'>
    <h1 class='collections-{{ section.id }}__title'>Collections</h1>
    <div class='collections-{{ section.id }}__grid'>
      {%- for collection in collections -%}
        <a href='{{ collection.url }}' class='collections-{{ section.id }}__card'>
          <div class='collections-{{ section.id }}__media'>
            {%- if collection.featured_image -%}
              {{
                collection.featured_image
                | image_url: width: 600
                | image_tag: loading: 'lazy', widths: '300, 600', alt: collection.title
              }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: '' }}
            {%- endif -%}
          </div>
          <span class='collections-{{ section.id }}__name'>{{ collection.title }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Collections list", "settings": [] }
{% endschema %}
