{% comment %} Institutional block (text + image). Depends on: none. {% endcomment %}
{% style %}
  .about-{{ section.id }} { padding: var(--section-space) 0; }
  .about-{{ section.id }}__grid { display: grid; grid-template-columns: 1fr; gap: 32px; align-items: center; }
  .about-{{ section.id }}__media { aspect-ratio: 4 / 3; border-radius: 16px; overflow: hidden; background: var(--color-surface); }
  .about-{{ section.id }}__media img, .about-{{ section.id }}__media svg { width: 100%; height: 100%; object-fit: cover; }
  .about-{{ section.id }}__eyebrow { font-size: var(--f1); font-weight: 600; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.06em; }
  .about-{{ section.id }}__title { font-size: var(--f6); margin: 10px 0 16px; }
  .about-{{ section.id }}__text { color: var(--color-muted); font-size: var(--f3); margin-bottom: 24px; }
  .about-{{ section.id }}__cta { display: inline-block; padding: 12px 24px; background: var(--color-brand); color: var(--color-bg); border-radius: 10px; font-weight: 600; }
  @media (min-width: 800px) { .about-{{ section.id }}__grid { grid-template-columns: 1fr 1fr; } .about-{{ section.id }}--reversed .about-{{ section.id }}__media { order: 2; } }
{% endstyle %}

<section
  class='about-{{ section.id }}{% if section.settings.image_right %} about-{{ section.id }}--reversed{% endif %}'
  data-reveal='up'
>
  <div class='container about-{{ section.id }}__grid'>
    <div class='about-{{ section.id }}__media'>
      {%- if section.settings.image -%}
        {{
          section.settings.image
          | image_url: width: 800
          | image_tag: loading: 'lazy', widths: '400, 800', alt: section.settings.title
        }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: '' }}
      {%- endif -%}
    </div>
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <p class='about-{{ section.id }}__eyebrow'>{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class='about-{{ section.id }}__title'>{{ section.settings.title }}</h2>
      <div class='about-{{ section.id }}__text'>{{ section.settings.text }}</div>
      {%- if section.settings.cta != blank -%}
        <a href='{{ section.settings.link | default: '#' }}' class='about-{{ section.id }}__cta'>
          {{ section.settings.cta }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "checkbox", "id": "image_right", "label": "Image on the right", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "About us" },
    { "type": "text", "id": "title", "label": "Title", "default": "A store built for you" },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Tell your brand's story and values in a few lines.</p>"
    },
    { "type": "text", "id": "cta", "label": "Button label", "default": "Learn more" },
    { "type": "url", "id": "link", "label": "Link" }
  ],
  "presets": [{ "name": "About" }]
}
{% endschema %}
