{% comment %} Service / value-prop cards. Blocks. Depends on: none. {% endcomment %}
{% style %}
  .services-{{ section.id }} { padding: var(--section-space) 0; }
  .services-{{ section.id }}__title { font-size: var(--f6); text-align: center; margin-bottom: 32px; }
  .services-{{ section.id }}__grid { display: grid; grid-template-columns: 1fr; gap: 20px; }
  .services-{{ section.id }}__card { padding: 28px; border: 1px solid var(--color-border); border-radius: 16px; transition: box-shadow 0.3s ease, transform 0.3s ease; }
  .services-{{ section.id }}__card:hover { box-shadow: 0 12px 40px rgba(0, 0, 0, 0.06); transform: translateY(-2px); }
  .services-{{ section.id }}__icon { width: 48px; height: 48px; display: grid; place-items: center; border-radius: 12px; background: var(--color-surface); color: var(--color-brand); margin-bottom: 16px; }
  .services-{{ section.id }}__name { font-size: var(--f4); margin-bottom: 8px; }
  .services-{{ section.id }}__text { color: var(--color-muted); font-size: var(--f2); }
  @media (min-width: 700px) { .services-{{ section.id }}__grid { grid-template-columns: repeat(3, 1fr); } }
{% endstyle %}

<section class='services-{{ section.id }}' data-reveal='up'>
  <div class='container'>
    {%- if section.settings.title != blank -%}
      <h2 class='services-{{ section.id }}__title'>{{ section.settings.title }}</h2>
    {%- endif -%}
    <div class='services-{{ section.id }}__grid'>
      {%- for block in section.blocks -%}
        <div class='services-{{ section.id }}__card' {{ block.shopify_attributes }}>
          <div class='services-{{ section.id }}__icon'>
            <svg viewBox='0 0 24 24' width='24' height='24' fill='none' stroke='currentColor' stroke-width='2'>
              <path d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h3 class='services-{{ section.id }}__name'>{{ block.settings.title }}</h3>
          <p class='services-{{ section.id }}__text'>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Services",
  "settings": [{ "type": "text", "id": "title", "label": "Title", "default": "Why shop with us" }],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Fast shipping" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Get your order quickly and safely." }
      ]
    }
  ],
  "presets": [{ "name": "Services", "blocks": [{ "type": "service" }, { "type": "service" }, { "type": "service" }] }]
}
{% endschema %}
