{% comment %}
  Global toast. Usage: Theme.alert('Message', 'success'|'error', 3000)
  Depends on: none.
{% endcomment %}
<div class='alert' data-alert role='status' aria-live='polite' hidden>
  <span data-alert-text></span>
</div>

{% stylesheet %}
  .alert {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 10002;
    max-width: 90vw;
    padding: 14px 20px;
    border-radius: 10px;
    background: var(--color-brand);
    color: var(--color-bg);
    font-size: var(--f1);
    font-weight: 500;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    transform: translateX(120%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .alert[hidden] {
    display: block;
  }
  .alert.is-visible {
    transform: translateX(0);
  }
  .alert.success {
    background: #16a34a;
  }
  .alert.error {
    background: #dc2626;
  }
{% endstylesheet %}

{% javascript %}
  window.Theme = window.Theme || {};
  (function () {
    var el = document.querySelector('[data-alert]');
    var text = el && el.querySelector('[data-alert-text]');
    var timer = null;
    window.Theme.alert = function (message, type, duration) {
      if (!el) return;
      el.className = 'alert';
      if (type) el.classList.add(type);
      text.textContent = message;
      requestAnimationFrame(function () {
        el.classList.add('is-visible');
      });
      clearTimeout(timer);
      timer = setTimeout(function () {
        el.classList.remove('is-visible');
      }, duration || 3000);
    };
  })();
{% endjavascript %}
