{% comment %} Trust badges strip (icon + text). Blocks. Depends on: none. {% endcomment %}
{% style %}
  .trust-{{ section.id }} { padding: clamp(24px, 4vw, 40px) 0; border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .trust-{{ section.id }}__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .trust-{{ section.id }}__item { display: flex; align-items: center; justify-content: center; gap: 12px; text-align: left; }
  .trust-{{ section.id }}__icon { color: var(--color-brand); flex-shrink: 0; }
  .trust-{{ section.id }}__name { font-weight: 600; font-size: var(--f2); }
  .trust-{{ section.id }}__text { color: var(--color-muted); font-size: var(--f1); }
  @media (min-width: 800px) { .trust-{{ section.id }}__grid { grid-template-columns: repeat(4, 1fr); } }
{% endstyle %}

<section class='trust-{{ section.id }}' data-reveal>
  <div class='container trust-{{ section.id }}__grid'>
    {%- for block in section.blocks -%}
      <div class='trust-{{ section.id }}__item' {{ block.shopify_attributes }}>
        <span class='trust-{{ section.id }}__icon'>
          <svg viewBox='0 0 24 24' width='28' height='28' fill='none' stroke='currentColor' stroke-width='1.8'>
            <path d="M12 2l8 4v6c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6l8-4z"/><path d="M9 12l2 2 4-4"/>
          </svg>
        </span>
        <span>
          <span class='trust-{{ section.id }}__name'>{{ block.settings.title }}</span>
          <br>
          <span class='trust-{{ section.id }}__text'>{{ block.settings.text }}</span>
        </span>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Trust badges",
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Secure checkout" },
        { "type": "text", "id": "text", "label": "Text", "default": "Protected payment" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust badges",
      "blocks": [{ "type": "badge" }, { "type": "badge" }, { "type": "badge" }, { "type": "badge" }]
    }
  ]
}
{% endschema %}
