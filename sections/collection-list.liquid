{% comment %} Collection list (circles). Configurable blocks. Depends on: none. {% endcomment %}
{% style %}
  .collection-list-{{ section.id }} { padding: var(--section-space) 0; }
  .collection-list-{{ section.id }}__title { font-size: var(--f6); text-align: center; margin-bottom: 32px; }
  .collection-list-{{ section.id }}__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; max-width: 720px; margin: 0 auto; }
  .collection-list-{{ section.id }}__item { display: flex; flex-direction: column; align-items: center; gap: 10px; text-align: center; }
  .collection-list-{{ section.id }}__circle { width: clamp(88px, 18vw, 120px); aspect-ratio: 1; border-radius: 50%; overflow: hidden; background: var(--color-surface); }
  .collection-list-{{ section.id }}__circle img, .collection-list-{{ section.id }}__circle svg { width: 100%; height: 100%; object-fit: cover; }
  .collection-list-{{ section.id }}__name { font-family: var(--font-heading); font-weight: 600; font-size: var(--f2); }
  @media (min-width: 700px) { .collection-list-{{ section.id }}__grid { grid-template-columns: repeat(4, 1fr); } }
{% endstyle %}

<section class='collection-list-{{ section.id }}' data-reveal='up'>
  <div class='container'>
    {%- if section.settings.title != blank -%}
      <h2 class='collection-list-{{ section.id }}__title'>{{ section.settings.title }}</h2>
    {%- endif -%}
    <div class='collection-list-{{ section.id }}__grid'>
      {%- for block in section.blocks -%}
        <a
          href='{{ block.settings.link | default: '#' }}'
          class='collection-list-{{ section.id }}__item'
          {{ block.shopify_attributes }}
        >
          <span class='collection-list-{{ section.id }}__circle'>
            {%- if block.settings.image -%}
              {{
                block.settings.image
                | image_url: width: 240
                | image_tag: loading: 'lazy', widths: '120, 240', alt: block.settings.name
              }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: '' }}
            {%- endif -%}
          </span>
          <span class='collection-list-{{ section.id }}__name'>{{ block.settings.name }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection list",
  "settings": [{ "type": "text", "id": "title", "label": "Title", "default": "Categories" }],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "name", "label": "Name", "default": "Category" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list",
      "blocks": [{ "type": "collection" }, { "type": "collection" }, { "type": "collection" }, { "type": "collection" }]
    }
  ]
}
{% endschema %}
