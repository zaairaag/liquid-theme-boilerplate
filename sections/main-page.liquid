{% comment %} Generic page (title + rich text). Depends on: none. {% endcomment %}
{% style %}
  .page-{{ section.id }} { padding: var(--section-space) 0; }
  .page-{{ section.id }}__inner { max-width: 760px; margin: 0 auto; }
  .page-{{ section.id }}__title { font-size: var(--f7); margin-bottom: 24px; }
  .page-{{ section.id }}__content { line-height: 1.7; }
  .page-{{ section.id }}__content > * + * { margin-top: 1em; }
{% endstyle %}

<section class='page-{{ section.id }}' data-reveal='up'>
  <div class='container page-{{ section.id }}__inner'>
    <h1 class='page-{{ section.id }}__title'>{{ page.title }}</h1>
    <div class='page-{{ section.id }}__content rte'>{{ page.content }}</div>
  </div>
</section>

{% schema %}
{ "name": "Page", "settings": [] }
{% endschema %}
