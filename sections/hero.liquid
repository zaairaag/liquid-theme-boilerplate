{% comment %} Depends on: none. Simple hero with mock content. {% endcomment %}
{% style %}
  .hero-{{ section.id }} { background: var(--color-surface); padding: clamp(48px, 9vw, 110px) 0; }
  .hero-{{ section.id }}__inner { max-width: 640px; }
  .hero-{{ section.id }}__eyebrow { font-size: var(--f1); font-weight: 600; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.06em; }
  .hero-{{ section.id }}__title { font-size: var(--f8); line-height: 1.05; margin: 12px 0 16px; }
  .hero-{{ section.id }}__text { font-size: var(--f3); color: var(--color-muted); margin-bottom: 28px; }
  .hero-{{ section.id }}__btn { display: inline-block; padding: 14px 28px; background: var(--color-brand); color: var(--color-bg); border-radius: 10px; font-weight: 600; }
  .hero-{{ section.id }}__btn:hover { background: var(--color-accent); }
{% endstyle %}

<section class='hero-{{ section.id }}' data-reveal>
  <div class='container hero-{{ section.id }}__inner'>
    {%- if section.settings.eyebrow != blank -%}
      <p class='hero-{{ section.id }}__eyebrow'>{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h1 class='hero-{{ section.id }}__title'>{{ section.settings.title }}</h1>
    {%- if section.settings.text != blank -%}
      <p class='hero-{{ section.id }}__text'>{{ section.settings.text }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href='{{ section.settings.button_link | default: '#' }}' class='hero-{{ section.id }}__btn'>
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New" },
    { "type": "text", "id": "title", "label": "Title", "default": "A bold headline for your store" },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Describe your store's value proposition in one short, clear sentence."
    },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
