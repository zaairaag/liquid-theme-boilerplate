<!doctype html>
<html lang='{{ request.locale.iso_code }}'>
  <head>
    <meta charset='utf-8'>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'>

    {%- comment -%}
      js-reveal: enables entrance effects only when JS is available (no JS = content shows normally).
      pre-load: disables transitions during the first paint (prevents drawers/toasts sliding on load).
    {%- endcomment -%}
    <script>
      document.documentElement.classList.add('js-reveal', 'pre-load');
    </script>

    {%- comment -%} LCP image preload slot (fill per template, e.g. the home hero) {%- endcomment -%}
    {%- comment -%} <link rel="preload" as="image" href="..." fetchpriority="high"> {%- endcomment -%}

    <title>
      {{ page_title }}
      {% unless page_title contains shop.name %}&ndash; {{ shop.name }}{% endunless %}
    </title>
    {%- if page_description %}<meta name='description' content='{{ page_description | escape }}'>{% endif %}
    {%- if canonical_url != blank %}<link rel='canonical' href='{{ canonical_url }}'>{% endif %}

    <meta property='og:site_name' content='{{ shop.name }}'>
    <meta property='og:title' content='{{ page_title | escape }}'>
    <meta property='og:type' content='{% if request.page_type == 'product' %}product{% else %}website{% endif %}'>
    <meta property='og:url' content='{{ canonical_url | default: shop.url }}'>
    <meta name='theme-color' content='{{ settings.color_brand | default: '#1A1A1A' }}'>

    {% render 'seo-jsonld' %}

    {{ settings.body_font | font_face: font_display: 'swap' }}
    {{ settings.heading_font | font_face: font_display: 'swap' }}

    <style>
      /* ===== Reset (inlined to avoid one render-blocking request) ===== */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html {
        line-height: 1.15;
        -webkit-text-size-adjust: 100%;
        background-color: var(--color-bg);
        scroll-behavior: smooth;
        scrollbar-gutter: stable; /* prevents the horizontal "jump" between page loads */
      }
      body {
        font-family: var(--font-body);
        font-weight: 400;
        line-height: 1.6;
        color: var(--color-text);
        background-color: var(--color-bg);
        -webkit-font-smoothing: antialiased;
      }
      body.is-locked { overflow: hidden; }
      img, svg { display: block; max-width: 100%; height: auto; }
      a { color: inherit; text-decoration: none; }
      button { font: inherit; cursor: pointer; background: none; border: 0; }
      h1, h2, h3, h4, h5, h6 { font-family: var(--font-heading); font-weight: 700; line-height: 1.2; }
      ::selection { background: var(--color-brand); color: var(--color-bg); }

      /* ===== Design tokens ===== */
      :root {
        --color-brand: {{ settings.color_brand | default: '#1A1A1A' }};
        --color-brand-dark: {{ settings.color_brand_dark | default: '#000000' }};
        --color-accent: {{ settings.color_accent | default: '#0A7CFF' }};
        --color-text: {{ settings.color_text | default: '#1A1A1A' }};
        --color-bg: {{ settings.color_background | default: '#FFFFFF' }};
        --color-surface: #F6F7F8;
        --color-muted: #717171;
        --color-border: #E5E7EB;

        --font-heading: {{ settings.heading_font.family }}, {{ settings.heading_font.fallback_families }};
        --font-body: {{ settings.body_font.family }}, {{ settings.body_font.fallback_families }};

        --f0: clamp(0.7rem, 0.9vw, 0.78rem);
        --f1: clamp(0.8rem, 1vw, 0.9rem);
        --f2: clamp(0.9rem, 1.1vw, 1rem);
        --f3: clamp(1rem, 1.3vw, 1.15rem);
        --f4: clamp(1.15rem, 1.6vw, 1.4rem);
        --f5: clamp(1.4rem, 2vw, 1.8rem);
        --f6: clamp(1.7rem, 2.6vw, 2.2rem);
        --f7: clamp(2rem, 3.4vw, 2.8rem);
        --f8: clamp(2.4rem, 5vw, 3.8rem);

        --max-width: 1280px;
        --section-space: clamp(40px, 6vw, 80px);
      }

      .container { max-width: var(--max-width); margin: 0 auto; padding: 0 clamp(16px, 4vw, 32px); }

      .skip-link {
        position: absolute; top: -60px; left: 16px; z-index: 10000;
        background: var(--color-brand); color: var(--color-bg);
        padding: 12px 20px; border-radius: 8px; font-weight: 600;
        transition: top 0.2s ease;
      }
      .skip-link:focus { top: 16px; }

      /* ===== Anti-flash: no transitions during the first paint ===== */
      .pre-load * { transition: none !important; }

      /* ===== Entrance effects (opt-in via data-reveal) ===== */
      .js-reveal [data-reveal] { opacity: 0; transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.16, 1, 0.3, 1); }
      .js-reveal [data-reveal='up'] { transform: translateY(24px); }
      .js-reveal [data-reveal].is-revealed { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) {
        .js-reveal [data-reveal] { opacity: 1; transform: none; transition: none; }
      }
    </style>

    {{ content_for_header }}
  </head>

  <body>
    <a href='#main' class='skip-link'>{{ 'general.accessibility.skip_to_content' | t }}</a>

    {% render 'alert' %}
    {% render 'cart-drawer' %}
    {% render 'favorites' %}

    {% section 'header' %}

    <main id='main'>
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    <script>
      (function () {
        var html = document.documentElement;
        function init() {
          html.classList.remove('pre-load'); // re-enable transitions after the first paint
          var targets = document.querySelectorAll('[data-reveal]');
          if (!targets.length) return;
          if (!('IntersectionObserver' in window)) {
            for (var i = 0; i < targets.length; i++) targets[i].classList.add('is-revealed');
            return;
          }
          var obs = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (e) {
                if (e.isIntersecting) {
                  e.target.classList.add('is-revealed');
                  obs.unobserve(e.target);
                }
              });
            },
            { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
          );
          for (var j = 0; j < targets.length; j++) obs.observe(targets[j]);
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
        window.addEventListener('load', function () {
          html.classList.remove('pre-load');
        });
      })();
    </script>
  </body>
</html>
